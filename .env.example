# Ejemplo de variables de entorno para desarrollo y despliegue
# Copia este archivo a `.env` y completa los valores reales.

# Clave secreta de Django (no subir al repositorio)
SECRET_KEY=django-insecure-REEMPLAZA_POR_TU_SECRET

# DEBUG: True para desarrollo local, False para producción
DEBUG=True

# Hosts permitidos (coma-separados). En Vercel pon el dominio de tu proyecto.
ALLOWED_HOSTS=localhost,127.0.0.1

# URL de conexión a la base de datos PostgreSQL (Neon)
# Obténla desde el panel de Neon. Ejemplo:
# postgres://usuario:password@ep-xxxxx.us-west-2.aws.neon.tech:5432/nombre_db?sslmode=require
DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require

# Opcional: Forzar comportamientos específicos (ejemplo)
# EMAIL_HOST=...
# OTHER_SETTING=...
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Local: SQLite
DATABASE_URL=sqlite:///db.sqlite3

# Producción: Neon PostgreSQL (descomentar y poner tu cadena)
# DATABASE_URL=postgresql://usuario:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require